---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const albums = (await getCollection("albums"))
  .filter((album) => album.data.publish !== false)
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const heroContent = {
  title: "Gallery",
  description: "",
};
---

<Layout>
  <InnerHero content={heroContent} />

  <section class="site-container px-4 pt-8 pb-base">

    {albums.length === 0 && (
      <p class="text-center text-body-base">No albums found.</p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">

      {albums.map((album) => {
        const slug = album.slug ?? album.id;

        return (
          <a
            href={`/gallery/${slug}`}
            class="group block rounded-xl overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-white"
          >
            <div class="relative w-full h-[320px] overflow-hidden rounded-t-xl">
              <Image
                src={album.data.cover}
                alt={album.data.title}
                width={1600}
                height={1000}
                quality={100}
                format="webp"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />

              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>

            <div class="p-5 bg-[var(--color-background-light)] border border-[var(--color-background-dark)] rounded-b-xl">
              <h3 class="text-h4 font-semibold text-headline transition-colors duration-300 group-hover:text-[var(--color-primary)]">
                {album.data.title}
              </h3>

              {album.data.description && (
                <p class="mt-2 text-small text-body-base line-clamp-2">
                  {album.data.description}
                </p>
              )}
            </div>

          </a>
        );
      })}

    </div>
  </section>
</Layout>
