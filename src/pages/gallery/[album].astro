---
import Layout from "@layouts/Layout.astro";
import InnerHero from "@components/sections/InnerHero.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const albums = await getCollection("albums");

  return albums.map((album) => ({
    params: {
      album: album.slug ?? album.id,
    },
  }));
}

const { album } = Astro.params;

const mainAlbums = await getCollection("albums");
const mainAlbum = mainAlbums.find((a) => (a.slug ?? a.id) === album);

const subalbums = await getCollection("subalbums");

const relatedSubalbums = subalbums
  .filter((sub) => sub.id.startsWith(album + "/"))
  .filter((sub) => sub.data.publish !== false)
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const heroContent = {
  title: mainAlbum?.data.title || album,
  description: mainAlbum?.data.description || "",
};
---

<Layout>
  <InnerHero content={heroContent} />

  <section class="site-container px-4 pt-8 pb-base">

    <a
      href="/gallery"
      class="inline-block mb-6 text-[var(--color-primary)] hover:underline"
    >
      ← Back to Gallery
    </a>

    {relatedSubalbums.length === 0 && (
      <p class="text-center text-body-base">
        No sub albums found.
      </p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

      {relatedSubalbums.map((sub) => {
        const subSlug = sub.id.split("/").pop();

        return (
          <a
            href={`/gallery/${album}/${subSlug}`}
            class="group block rounded-xl overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-white"
          >
            <div class="relative w-full h-[260px] overflow-hidden rounded-xl">

              <Image
                src={sub.data.cover}
                alt={sub.data.title}
                width={1200}
                height={800}
                quality={100}
                format="webp"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />

              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

            </div>

            <div class="p-4 text-center">
              <h3 class="text-h5 font-semibold capitalize">
                {sub.data.title}
              </h3>
            </div>

          </a>
        );
      })}

    </div>
  </section>
</Layout>
